# NPM Configuration for Mobile_Celeuma
# Este ficheiro resolve conflitos de dependências automaticamente

# Usar apenas dependências exatas (sem --force necessário)
legacy-peer-deps=true

# Melhorar performance de instala
fetch-timeout=60000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Usar npm ci em CI/CD (mais seguro que npm install)
# Em local: npm install normalmente
